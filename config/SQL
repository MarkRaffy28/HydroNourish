CREATE DATABASE db_hydronourish_no_gsm;

CREATE TABLE users (
  id INT AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(255) NOT NULL,
  email VARCHAR(100) NOT NULL,
  username VARCHAR(50) NOT NULL,
  password VARCHAR(255) NOT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS farm_schedules (
  id INT AUTO_INCREMENT PRIMARY KEY,
  user_id INT NOT NULL,
  schedule_date DATE NOT NULL,
  task_type VARCHAR(30) NOT NULL,
  task_name VARCHAR(120) NOT NULL,
  task_time TIME NOT NULL DEFAULT '06:00:00',
  task_notes TEXT,
  status ENUM('scheduled','in_progress','completed','cancelled') DEFAULT 'scheduled',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  INDEX idx_date_user (schedule_date, user_id)
);

CREATE TABLE sensor_logs  (
  id              INT                            AUTO_INCREMENT PRIMARY KEY,
  soil_percent    TINYINT     UNSIGNED           DEFAULT NULL,
  water_level     TINYINT     UNSIGNED           DEFAULT NULL,
  fert_level      TINYINT     UNSIGNED           DEFAULT NULL,
  temperature     FLOAT                          DEFAULT NULL,
  humidity        FLOAT                          DEFAULT NULL,
  pressure        FLOAT                          DEFAULT NULL,
  water_distance  FLOAT                          DEFAULT NULL,
  fert_distance   FLOAT                          DEFAULT NULL,
  watering        TINYINT(1)            NOT NULL DEFAULT 0,
  fertigating     TINYINT(1)            NOT NULL DEFAULT 0,
  water_low       TINYINT(1)            NOT NULL DEFAULT 0,
  fert_low        TINYINT(1)            NOT NULL DEFAULT 0,
  rtc_time        VARCHAR(50)                    DEFAULT NULL,
  soil_error      TINYINT(1)            NOT NULL DEFAULT 0,
  water_error     TINYINT(1)            NOT NULL DEFAULT 0,
  fert_error      TINYINT(1)            NOT NULL DEFAULT 0,
  hum_error       TINYINT(1)            NOT NULL DEFAULT 0,
  temp_error      TINYINT(1)            NOT NULL DEFAULT 0,
  pres_error      TINYINT(1)            NOT NULL DEFAULT 0,
  rtc_error       TINYINT(1)            NOT NULL DEFAULT 0,
  created_at      DATETIME              NOT NULL DEFAULT CURRENT_TIMESTAMP,
  INDEX idx_created_at (created_at)
);

CREATE TABLE commands (
  id INT AUTO_INCREMENT PRIMARY KEY,
  irrigation TINYINT(1) DEFAULT 0,
  fertigation TINYINT(1) DEFAULT 0,
  status ENUM('pending','done','failed') DEFAULT 'pending',
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  executed_at TIMESTAMP NULL
);

CREATE TABLE options (
  id INT AUTO_INCREMENT PRIMARY KEY,
  water_watering_percent INT DEFAULT 50,
  tank_low_percent INT DEFAULT 20,
  tank_high_percent INT DEFAULT 80,
  water_full_cm INT DEFAULT 10,
  water_empty_cm INT DEFAULT 25,
  fert_full_cm INT DEFAULT 10,
  fert_empty_cm INT DEFAULT 25,
  fertigation_enabled TINYINT(1) DEFAULT 1,
  fert_interval_minutes INT DEFAULT 1,
  fert_duration_ms INT DEFAULT 5000,
  buzzer_enabled TINYINT(1) DEFAULT 1,
  buzzer_alert_interval_ms INT DEFAULT 60000,
  lcd_enabled TINYINT(1) DEFAULT 1,
  backlight_enabled TINYINT(1) DEFAULT 1,
  rtc_set_time VARCHAR(50) DEFAULT '',
  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);